# ─── Kotak Neo Credentials ────────────────────────────────────────────────────

# Static API key (Authorization header) — UUID from the Kotak developer portal
API_KEY=0230a256-7402-41b4-9bf9-5dbe40cb3ece

# Registered mobile number (with country code)
MOBILE_NUMBER=+918229020370

# Kotak UCC / client code (shown on your Kotak Neo profile)
UCC=XCGWJ

# ─── Optional: skip TOTP prompt by storing a valid session ────────────────────
# After first login, copy the sid and auth token printed in the console here.
# Leave blank to be prompted for TOTP on every start.
SESSION_SID=
SESSION_AUTH=

# ─── Symbol Config ────────────────────────────────────────────────────────────
# Comma-separated — positions must match across all three fields.
# SYMBOL         : Trading symbol as recognised by the order API
# INSTRUMENT_TOKEN: Numeric token used in the market-data / scrip-details URL
# EXCHANGE_SEGMENT: mcx_fo | nse_fo | nse_cm | bse_cm | cde_fo

SYMBOL=CRUDEOIL26MAYFUT
INSTRUMENT_TOKEN=12345
EXCHANGE_SEGMENT=mcx_fo

# Multiple symbols example:
# SYMBOL=CRUDEOIL26MAYFUT,NATURALGAS26MAYFUT
# INSTRUMENT_TOKEN=12345,67890
# EXCHANGE_SEGMENT=mcx_fo,mcx_fo

# ─── Order Config ─────────────────────────────────────────────────────────────

# Product type: NRML | MIS | CNC
PRODUCT=NRML

# Order type: L (Limit) | MKT | SL | SL-M
ORDER_TYPE=L

# Transaction type: B (Buy) | S (Sell)
TRANSACTION_TYPE=B

# Lot quantity
QUANTITY=1

# ─── Bot Config ───────────────────────────────────────────────────────────────

# Points difference between LTP and best bid/ask that triggers action
PRICE_DIFF_THRESHOLD=200

# How often to poll in milliseconds
POLL_INTERVAL_MS=5000
